# Azure AD App Registration
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here

# GitHub Pages redirect URI (change to your org/repo)
VITE_REDIRECT_URI=https://your-org.github.io/sap-onepager-app/

# (Optional) Override the first worksheet name in the Excel file
VITE_WORKSHEET_NAME=

# (Optional) Override SharePoint drive ID if auto-detection fails
VITE_DRIVE_ID=
